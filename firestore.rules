rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/{docId} {
      allow read: if true;
    }

    // 1. Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }

    // 2. Validation Blueprint for FoodScan
    function isValidFoodScan(data) {
      return data.foodName is string && data.foodName.size() <= 100 &&
             data.calories is number && data.calories >= 0 &&
             (!('proteinG' in data) || data.proteinG is number) &&
             (!('fatG' in data) || data.fatG is number) &&
             (!('carbohydratesG' in data) || data.carbohydratesG is number) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2097152)) && // 2MB limit
             data.timestamp is timestamp &&
             isOwner(data.userId);
    }

    function isValidProfile(data) {
      let goals = ["Build Muscle", "Lose Fat", "Improve Performance", "General Health", "Gain muscle", "Weight gain", "Weight loss", "Athletic performance"];
      return (data.goal in goals) &&
             data.onboardingComplete == true &&
             isOwner(data.uid);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidProfile(incoming());
    }

    match /coach_chats/{chatId} {
       allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
       allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
       allow create: if isSignedIn() && isOwner(incoming().userId);
    }

    match /mealPlans/{planId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /progress/{logId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /scans/{scanId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidId(scanId) &&
                    isValidFoodScan(incoming()) &&
                    incoming().timestamp == request.time;
      
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    function isValidWaterLog(data) {
      return data.amountMl is number && data.amountMl > 0 &&
             data.timestamp is timestamp &&
             isOwner(data.userId);
    }

    match /water/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                    isValidId(logId) &&
                    isValidWaterLog(incoming()) &&
                    incoming().timestamp == request.time;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
