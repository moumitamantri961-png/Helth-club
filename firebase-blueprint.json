{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user goals, physical metrics, and settings",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "goal": { "type": "string", "enum": ["Gain muscle", "Lose fat", "Weight gain", "Weight loss", "Athletic performance", "General health"] },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "activityLevel": { "type": "string" },
        "workoutsPerWeek": { "type": "number" },
        "dietType": { "type": "string" },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "string" },
        "location": { "type": "string" },
        "sleepDuration": { "type": "number" },
        "injuries": { "type": "string" },
        "medicalRestrictions": { "type": "string" },
        "dailySchedule": { "type": "string" },
        "dailyCalorieGoal": { "type": "number" },
        "dailyProteinGoal": { "type": "number" },
        "dailyCarbsGoal": { "type": "number" },
        "dailyFatGoal": { "type": "number" },
        "dailyWaterGoal": { "type": "number" },
        "onboardingComplete": { "type": "boolean" },
        "coachOnboardingComplete": { "type": "boolean" },
        "isPremium": { "type": "boolean" }
      },
      "required": ["goal", "onboardingComplete"]
    },
    "MealPlan": {
      "title": "Meal Plan",
      "properties": {
        "userId": { "type": "string" },
        "meals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "name": { "type": "string" },
              "calories": { "type": "number" },
              "protein": { "type": "number" },
              "carbs": { "type": "number" },
              "fat": { "type": "number" },
              "portion": { "type": "string" },
              "healthScore": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ProgressLog": {
      "title": "Progress Log",
      "properties": {
        "userId": { "type": "string" },
        "weight": { "type": "number" },
        "photoUrl": { "type": "string" },
        "energyLevel": { "type": "number" },
        "sleepHours": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "FoodScan": {
      "title": "Food Scan",
      "description": "Represents a single food nutritional analysis scan",
      "type": "object",
      "properties": {
        "foodName": { "type": "string" },
        "confidence": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "portionSize": { "type": "string" },
        "calories": { "type": "number" },
        "proteinG": { "type": "number" },
        "fatG": { "type": "number" },
        "carbohydratesG": { "type": "number" },
        "sugarG": { "type": "number" },
        "sodiumMg": { "type": "number" },
        "fiberG": { "type": "number" },
        "allergens": { "type": "array", "items": { "type": "string" } },
        "healthTip": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["foodName", "calories", "timestamp", "userId"]
    },
    "WaterLog": {
      "title": "Water Log",
      "properties": {
        "amountMl": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      }
    },
    "CoachChat": {
      "title": "Coach Chat Message",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["coach", "user"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "message", "timestamp"]
    }
  },
  "firestore": {
    "users": {
        "schema": "UserProfile",
        "description": "User specific goals and data"
    },
    "scans": {
      "schema": "FoodScan",
      "description": "Collection of nutritional analysis results"
    },
    "water": {
        "schema": "WaterLog",
        "description": "Daily hydration tracking"
    },
    "mealPlans": {
        "schema": "MealPlan",
        "description": "Personalized AI generated meal plans"
    },
    "progress": {
        "schema": "ProgressLog",
        "description": "Weekly progress tracking"
    },
    "coach_chats": {
        "schema": "CoachChat",
        "description": "Messages exchanged between user and AI coach"
    }
  }
}
